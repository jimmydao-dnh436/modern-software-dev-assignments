WEATHER_BASE_URL=https://api.open-meteo.com/v1
WEATHER_GEOCODING_BASE_URL=https://geocoding-api.open-meteo.com/v1
WEATHER_TIMEOUT_SECONDS=10
WEATHER_USER_AGENT=week3-mcp-weather-server-go/1.0
WEATHER_RETRY_ATTEMPTS=2
WEATHER_BACKOFF_SECONDS=0.2

MCP_HOST=127.0.0.1
MCP_PORT=8000
MCP_ALLOWED_ORIGINS=http://localhost:6274,http://127.0.0.1:6274

AUTH_REQUIRED=false

AUTH_ISSUER=https://<your-tenant>.auth0.com/
AUTH_AUDIENCE=https://weather-api.mcp
AUTH_REQUIRED_SCOPES=read:weather
AUTH_SECRET=your-hmac-secret-here